{
  "name": "deadline-rescue-agent",
  "version": "1.0.0",
  "description": "Deadline Rescue Agent - Vibe2Ship Hackathon 2026",
  "private": true,
  "scripts": {
    "install:frontend": "cd frontend && npm install",
    "build:server": "tsc --project tsconfig.server.json",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:server && npm run build:frontend",
    "start": "node dist-server/server.js",
    "dev": "ts-node server.ts"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "@types/ws": "^8.5.12",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
